# =============================================================================
# Coolify MCP Server — Environment Variables
# Copy this file to .env and fill in the values
# =============================================================================

# [REQUIRED] Your Coolify instance URL (no trailing slash)
# Example: https://coolify.yourdomain.com
COOLIFY_BASE_URL=https://coolify.example.com

# [REQUIRED] Coolify API access token
# Generate at: Coolify UI → Settings → API → Generate Token
COOLIFY_ACCESS_TOKEN=your-coolify-api-token-here

# [OPTIONAL] Port for the MCP HTTP/SSE server (default: 8000)
MCP_PORT=8000

# [OPTIONAL] Node environment (default: production)
NODE_ENV=production

# [OPTIONAL] Bearer token to protect the /sse endpoint
# If set, Antigravity must send: Authorization: Bearer <this-value>
# If empty, the endpoint is open (rely on network-level security)
MCP_AUTH_TOKEN=
